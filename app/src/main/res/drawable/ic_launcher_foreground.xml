<?xml version="1.0" encoding="utf-8"?>
<!--
    Simple open-book silhouette used as the launcher icon foreground.
    White on the deep-blue background defined in ic_launcher_background.xml.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Left page of the open book -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M54,30
            C54,30 36,33 28,40
            L28,78
            C36,71 54,68 54,68
            Z" />

    <!-- Right page of the open book -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M54,30
            C54,30 72,33 80,40
            L80,78
            C72,71 54,68 54,68
            Z" />

    <!-- Spine / centre line -->
    <path
        android:fillColor="#1A3A6B"
        android:pathData="M52,30 L56,30 L56,68 L52,68 Z" />

</vector>
